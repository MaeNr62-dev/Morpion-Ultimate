{
  "appId": "com.morpion.ultimate",
  "productName": "Morpion Ultimate",
  "copyright": "Copyright © 2025 Morpion Ultimate",
  "directories": {
    "output": "dist",
    "buildResources": "assets"
  },
  "files": [
    "main.js",
    "preload.js",
    "index.html",
    "styles/**/*",
    "scripts/**/*",
    "assets/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64", "ia32"] },
      { "target": "portable", "arch": ["x64"] }
    ],
    "icon": "assets/icons/icon.ico",
    "artifactName": "MorpionUltimate-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "assets/icons/icon.ico",
    "uninstallerIcon": "assets/icons/icon.ico",
    "license": "LICENSE",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Morpion Ultimate"
  },
  "linux": {
    "target": [
      { "target": "AppImage", "arch": ["x64"] },
      { "target": "deb",      "arch": ["x64"] }
    ],
    "icon": "assets/icons/icon.png",
    "category": "Game",
    "artifactName": "MorpionUltimate-${version}.${ext}"
  },
  "mac": {
    "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
    "icon": "assets/icons/icon.icns",
    "category": "public.app-category.games"
  },
  "publish": null
}
